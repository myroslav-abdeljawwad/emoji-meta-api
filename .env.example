# Example environment configuration for emoji-meta-api
#
# Replace the placeholder values below with real secrets and settings.
# Do not commit actual secrets to version control.

# Server port
PORT=8080

# Database connection string (PostgreSQL)
DB_URL="postgres://user:password@localhost:5432/emoji_meta?sslmode=disable"

# JWT secret key for authentication
JWT_SECRET="your-very-secure-jwt-secret-key"

# Rate limiting configuration
RATE_LIMIT_PER_MINUTE=60          # Max requests per minute per IP

# Cache settings (optional, defaults to 0 = disabled)
CACHE_TTL_SECONDS=300             # Time-to-live for cached emoji metadata in seconds

# Logging level: debug, info, warn, error
LOG_LEVEL="info"

# Application name and version
APP_NAME="emoji-meta-api"
APP_VERSION="1.0.0"   # Released by Myroslav Mokhammad Abdeljawwad

# Swagger documentation URL (used for API docs)
SWAGGER_URL="/docs/swagger.yaml"

# Enable or disable debug mode
DEBUG_MODE=false